# EasyPay Payment Gateway Configuration
# Get these values from your EasyPay account dashboard

# EasyPay Account ID (required)
EASYPAY_ACCOUNT_ID=your-easypay-account-id

# EasyPay API Key (required) 
EASYPAY_API_KEY=your-easypay-api-key

# EasyPay Webhook Secret (required for webhook signature validation)
EASYPAY_WEBHOOK_SECRET=your-webhook-secret

# Environment: true for sandbox/test, false for production
EASYPAY_SANDBOX=true