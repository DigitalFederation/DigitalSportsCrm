{
    "name": "digital-sports/digital-sports-crm",
    "version": "1.0.0",
    "type": "project",
    "description": "Open-source federation management platform built with Laravel and Vite.",
    "keywords": [
        "federation",
        "membership",
        "laravel",
        "vite"
    ],
    "license": "Apache-2.0",
    "require": {
        "php": "^8.2",
        "ext-gd": "*",
        "bacon/bacon-qr-code": "^2.0",
        "barryvdh/laravel-dompdf": "^2.0",
        "blade-ui-kit/blade-heroicons": "^2.6",
        "doctrine/dbal": "^3.6",
        "filament/actions": "^3.2",
        "filament/notifications": "^3.2",
        "filament/tables": "^3.2",
        "filament/widgets": "^3.2",
        "guzzlehttp/guzzle": "^7.2",
        "intervention/image": "^3.7",
        "kyslik/column-sortable": "^6.0",
        "larabug/larabug": "^3.0",
        "laravel/fortify": "^1.13",
        "laravel/framework": "^11",
        "laravel/jetstream": "^5.0",
        "laravel/pail": "^1.1",
        "laravel/sanctum": "^v4",
        "laravel/tinker": "^2.7",
        "league/commonmark": "^2.4",
        "league/flysystem-aws-s3-v3": "^3.0",
        "league/flysystem-path-prefixing": "^3.0",
        "livewire/livewire": "^3.6.4",
        "maatwebsite/excel": "^3.1",
        "mpociot/versionable": "^4.4",
        "power-components/livewire-powergrid": "^6.6",
        "sentry/sentry-laravel": "^4.15",
        "spatie/browsershot": "^5.0",
        "spatie/image": "^3.8",
        "spatie/laravel-activitylog": "^4.7",
        "spatie/laravel-backup": "^9.3",
        "spatie/laravel-honeypot": "^4.3",
        "spatie/laravel-medialibrary": "^11",
        "spatie/laravel-permission": "^6",
        "spatie/laravel-query-builder": "^5.1",
        "spatie/laravel-translatable": "^6.8",
        "tijsverkoyen/css-to-inline-styles": "^2.2",
        "ueberdosis/tiptap-php": "^1.4"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.7",
        "deployer/deployer": "^7.3",
        "fakerphp/faker": "^1.9.1",
        "itsgoingd/clockwork": "^5.1",
        "larastan/larastan": "^2.0",
        "laravel/boost": "1.8.9",
        "laravel/pint": "^1.11",
        "laravel/sail": "^1.0.1",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^8.1",
        "orchestra/testbench": "^9.2",
        "pestphp/pest": "^3.8",
        "pestphp/pest-plugin-laravel": "^3.2",
        "spatie/laravel-ignition": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Domain\\": "src/Domain/",
            "Support\\": "src/Support/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Helpers/InlineCssHelper.php",
            "app/Helpers/GlobalHelper.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
