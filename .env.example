APP_NAME="Digital Sports CRM"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=https://example.test
# Release version shown in the UI. Defaults to the release version in
# config/app.php — only set this to override it (e.g. custom builds/packaging).
#APP_VERSION=

# Public branding defaults are intentionally neutral for open-source releases.
# Private deployments should override these values in their environment.
# Put deployment-specific logos in an ignored public asset path.
FEDERATION_NAME="Example Federation"
FEDERATION_SHORT_NAME=DF
FEDERATION_PORTAL_NAME="${APP_NAME}"
FEDERATION_DESCRIPTION="Open-source federation management platform."
FEDERATION_ABOUT="This portal helps a federation manage members, entities, certifications, licenses, events, payments, and public directories."
FEDERATION_COUNTRY="Example Country"
FEDERATION_WEBSITE_URL=https://example.test
FEDERATION_WEBSITE_LABEL=example.test
FEDERATION_EMAIL=contact@example.test
FEDERATION_SUPPORT_EMAIL=contact@example.test
FEDERATION_ADDRESS="Example Street 1, 0000-000 Example City"
FEDERATION_PHONE="+000 000 000 000"
FEDERATION_MOBILE="+000 000 000 000"
# Optional: path (under public/) to your federation logo. Leave empty to write the federation name as text.
FEDERATION_LOGO_PATH=

INTERNATIONAL_FEDERATION_NAME="International Federation"
INTERNATIONAL_FEDERATION_SHORT_NAME=IF
INTERNATIONAL_FEDERATION_COUNTRY="Example Country"
INTERNATIONAL_FEDERATION_CODE=INTF00
INTERNATIONAL_FEDERATION_WEBSITE_URL=https://international.example.test
INTERNATIONAL_FEDERATION_WEBSITE_LABEL=international.example.test
INTERNATIONAL_FEDERATION_EMAIL=international@example.test
INTERNATIONAL_FEDERATION_ADDRESS="Example International Address"
INTERNATIONAL_FEDERATION_POSTAL="0000-000 Example City"
INTERNATIONAL_FEDERATION_LOGO_PATH=img/international-logo.svg
INTERNATIONAL_FEDERATION_SECONDARY_LOGO_PATH=img/international-logo.svg
PAYMENT_DESCRIPTOR_PREFIX=DF
PAYMENT_FALLBACK_EMAIL=billing@example.test

# Public map is empty until a deployment explicitly selects a country.
PUBLIC_MAP_ENABLED=true
PUBLIC_MAP_COUNTRY_ID=
PUBLIC_MAP_CENTER_LAT=0
PUBLIC_MAP_CENTER_LNG=0
PUBLIC_MAP_CENTER_ZOOM=2
PUBLIC_MAP_MAX_RESULTS=500
PUBLIC_MAP_INCLUDE_FEDERATIONS=false
PUBLIC_MAP_SHOW_CONTACT_DETAILS=false
PUBLIC_MAP_SPORT_COMMITTEE_CODE=SPORT
PUBLIC_MAP_DIVING_SERVICES_COMMITTEE_CODE=DIVINGSERVICES

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=digi_federation
DB_USERNAME=root
DB_PASSWORD= # gitleaks:allow empty example value
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

CERTIFICATION_IMPORT_DB_CONNECTION=mysql
CERTIFICATION_IMPORT_DB_HOST=127.0.0.1
CERTIFICATION_IMPORT_DB_PORT=3306
CERTIFICATION_IMPORT_DB_DATABASE=
CERTIFICATION_IMPORT_DB_USERNAME=
CERTIFICATION_IMPORT_DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
FILESYSTEM_PUBLIC_DRIVER=public
MEDIA_DISK=public
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=false

MEMCACHED_HOST=127.0.0.1
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.test"
MAIL_FROM_NAME="${APP_NAME}"

# Optional local-only default admin seeding. Keep disabled for shared deployments.
SEED_DEFAULT_ADMIN=false
DEFAULT_ADMIN_NAME=
DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_PASSWORD=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_URL=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

SENTRY_LARAVEL_DSN=
VITE_SENTRY_DSN_PUBLIC=
SENTRY_TRACES_SAMPLE_RATE=0.0

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# EasyPay (Portugal-specific payment gateway) — optional. Leave disabled to use the offline default.
EASYPAY_ENABLED=false
EASYPAY_SANDBOX=true
EASYPAY_ACCOUNT_ID=
EASYPAY_API_KEY=
EASYPAY_WEBHOOK_SECRET=

MOLONI_ENABLED=false
MOLONI_CLIENT_ID=
MOLONI_CLIENT_SECRET=
MOLONI_RECONCILIATION_ENABLED=false
MOLONI_RECONCILIATION_HOURS=72
MOLONI_RECONCILIATION_BATCH=50

DYNAMIC_MENU_ENABLED=true
DYNAMIC_MENU_CACHE=true
DYNAMIC_MENU_DEBUG=false
DYNAMIC_MENU_ADMIN=true
DYNAMIC_MENU_FEDERATION=true
DYNAMIC_MENU_ENTITY=true
DYNAMIC_MENU_INDIVIDUAL=true

USE_NEW_ROLE_SYSTEM=true
DEBUGBAR_ENABLED=false
SANCTUM_STATEFUL_DOMAINS=digital-sports.test

# Diving certification agencies this deployment recognizes (comma-separated, e.g. PADI,SSI,CMAS,SDI_TDI,DDI,GUE). Empty = none.
DIVING_CERTIFICATION_SYSTEMS=
