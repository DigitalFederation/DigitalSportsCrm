APP_NAME="Digital Sports CRM"
APP_ENV=testing
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=null
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=digi_federation_testing
DB_USERNAME=root
DB_PASSWORD= # gitleaks:allow empty example value
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

BROADCAST_DRIVER=log
CACHE_DRIVER=array
FILESYSTEM_DISK=local
FILESYSTEM_PUBLIC_DRIVER=public
MEDIA_DISK=public
QUEUE_CONNECTION=sync
SESSION_DRIVER=array
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=false

MAIL_MAILER=array
MAIL_FROM_ADDRESS="testing@example.test"
MAIL_FROM_NAME="${APP_NAME}"

SEED_DEFAULT_ADMIN=false
DEFAULT_ADMIN_NAME=
DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_PASSWORD=

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-1
AWS_BUCKET=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=

SENTRY_LARAVEL_DSN=
VITE_SENTRY_DSN_PUBLIC=
SENTRY_TRACES_SAMPLE_RATE=0.0

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

EASYPAY_SANDBOX=true
EASYPAY_ACCOUNT_ID=
EASYPAY_API_KEY=
EASYPAY_WEBHOOK_SECRET=

MOLONI_ENABLED=false
MOLONI_CLIENT_ID=
MOLONI_CLIENT_SECRET=
MOLONI_RECONCILIATION_ENABLED=false
MOLONI_RECONCILIATION_HOURS=72
MOLONI_RECONCILIATION_BATCH=50

DYNAMIC_MENU_ENABLED=true
DYNAMIC_MENU_CACHE=false
DYNAMIC_MENU_DEBUG=false
USE_NEW_ROLE_SYSTEM=true
DEBUGBAR_ENABLED=false
